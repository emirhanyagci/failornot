# Supabase
# URL'yi Supabase Dashboard → Project Settings → API → Project URL'den al
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Publishable key (eski adıyla "anon key").
# Dashboard → Project Settings → API → Project API Keys → "publishable"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Geriye dönük uyumluluk için aşağıdaki de desteklenir:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service role key — ASLA client'a sızmamalı.
# Admin endpoint'leri (kelime ekleme) bunu kullanır; RLS'i bypass eder.
# Dashboard → Project Settings → API → Project API Keys → "service_role"
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin paneli kredansiyelleri (/admin)
ADMIN_USERNAME=emirhan.yac
ADMIN_PASSWORD=12345679
# İsteğe bağlı: oturum imzası için ayrı secret. Tanımlamazsan parola kullanılır.
# ADMIN_SESSION_SECRET=rastgele-uzun-bir-string

# PartyKit (geliştirme için localhost, prod için Cloudflare URL)
NEXT_PUBLIC_PARTYKIT_HOST=127.0.0.1:1999
